# ========================================================================
# MAMS — Environment variables
# ========================================================================
# Скопировать в .env и заполнить. .env должен быть в .gitignore (и он там).
#
# Приоритеты:
#   P0 — нужно для DG-1 (Notion DBs + первая сессия Claude Code)
#   P1 — нужно для DG-3 (PM-Agent + первый специалист работают)
#   P2+ — по мере подключения ролей / скиллов
# ========================================================================

# ------------------------- P0 (обязательно) -------------------------

# Anthropic API — для Claude Code + Agent SDK
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Notion integration token
# Создать: https://www.notion.so/profile/integrations → + New integration
# Share со всеми необходимыми pages + DBs
NOTION_API_KEY=secret_REPLACE_ME

# Notion workspace id (опционально, для MCP sanity checks)
NOTION_WORKSPACE_ID=

# ------------------------- P1 (для Obsidian + Skill Inventory P1) -------------------------

# Obsidian Local REST API (Obsidian Community Plugin)
# Настраивается в Obsidian: Settings → Community plugins → Local REST API
OBSIDIAN_API_KEY=95b3c9ea6dd0e64d1ef11b2ec49bc683d215b4ff10d68faec258c8dc220fd1e7
OBSIDIAN_URL=https://127.0.0.1:27124

# Путь в vault до папки MAMS
OBSIDIAN_MAMS_FOLDER=MAMS

# ------------------------- Notion DB IDs (заполняются после DG-1) -------------------------

# Existing (уже созданы в Alex's workspace)
NOTION_DB_PROJECTS_REGISTRY_ID=
NOTION_DB_ACTIVITY_LOG_ID=a8f3ad98-9a8f-4809-996d-cf5441cd5f6a
NOTION_DS_ACTIVITY_LOG_ID=ac08f18a-1fe4-4acf-a598-06a594f1f9b0
NOTION_DB_COMMUNICATION_LOG_ID=

# New (создаются в DG-1, см. bootstrap/01-notion-dbs.md)
NOTION_DB_SPRINTS_ID=
NOTION_DB_TASKS_ID=
NOTION_DB_SKILLS_REGISTRY_ID=
NOTION_DB_DECISIONS_ID=
NOTION_DB_RISKS_ID=
NOTION_DB_RETROSPECTIVES_ID=

# ------------------------- P2: SEO stack -------------------------

AHREFS_API_KEY=
SEMRUSH_API_KEY=

# ------------------------- P2: Niche-Expert / Skill-Updater -------------------------

# Apify — 4 ключа для rotation (см. skill apify-api)
APIFY_TOKEN_PRIMARY=
APIFY_TOKEN_2=
APIFY_TOKEN_3=
APIFY_TOKEN_4=

# NotebookLM (unofficial auth)
NOTEBOOKLM_AUTH=

# ------------------------- P2: Link-Builder -------------------------

HUNTER_API_KEY=

# ------------------------- P2: Ads -------------------------

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=

LINKEDIN_ACCESS_TOKEN=

# ------------------------- P2: Analytics -------------------------

# GA4 service account (JSON-путь или base64)
GA4_SERVICE_ACCOUNT_JSON_PATH=

# GSC (OAuth creds)
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=

# Product analytics
MIXPANEL_SERVICE_ACCOUNT=
POSTHOG_API_KEY=
AMPLITUDE_API_KEY=

# ------------------------- P3: Dev -------------------------

VERCEL_ACCESS_TOKEN=
NETLIFY_AUTH_TOKEN=
FIGMA_ACCESS_TOKEN=

# GitHub (для Dev / QA + skill-vault Git operations)
GITHUB_TOKEN=

# ------------------------- P3: Skill Registry backend -------------------------

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ------------------------- Misc -------------------------

# Где у MAMS свой скилл-vault (для Skill-Updater Git operations)
MAMS_SKILL_VAULT_PATH=

# Log level для агентов
MAMS_LOG_LEVEL=info

# Max token budget per sprint (hard cap — Architecture Report §12)
MAMS_SPRINT_TOKEN_CAP_USD=50
