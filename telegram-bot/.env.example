TELEGRAM_BOT_TOKEN=<from_BotFather>
TELEGRAM_BOT_USERNAME=<auto-filled_at_startup_or_manual>
ALEX_TG_USER_ID=<auto-filled_on_first_start_or_manual>
ALEX_TG_USERNAME=<your_tg_username_without_@>
CLAUDE_CWD=/home/team/mams
CLAUDE_BIN=claude
SESSION_TTL_HOURS=24
ALEX_DAILY_LIMIT=0
USER_DAILY_LIMIT=30
LOG_LEVEL=INFO
PROJECT_MAP_PATH=/home/team/.mams/tg-project-map.json
SESSIONS_PATH=/home/team/.mams/tg-sessions.json
INBOX_DIR=/home/team/mams/telegram-bot/inbox
LOG_DIR=/home/team/mams/telegram-bot/logs
